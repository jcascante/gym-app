FROM node:22-alpine

WORKDIR /app

# Install deps at build time so they land in the image layer,
# not the bind-mounted source tree
COPY package.json package-lock.json ./
RUN npm install --legacy-peer-deps

# Source code is bind-mounted at runtime — no COPY needed here

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
