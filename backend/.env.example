PROJECT_NAME="Gym App API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Environment: "development" (uses SQLite) or "production" (uses PostgreSQL)
ENVIRONMENT="development"

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Database URLs (selected automatically based on ENVIRONMENT)
# Development: SQLite (no setup required)
SQLITE_URL="sqlite+aiosqlite:///./gym_app.db"

# Production: PostgreSQL
POSTGRES_URL="postgresql+asyncpg://user:password@localhost/gym_app"

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY="your-secret-key-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Program Builder Engine
# LOCAL DEV (HTTP mode — calls fastapi service):
#   ENGINE_INVOCATION_MODE=http
#   ENGINE_URL=http://program-builder:8000 (Docker Compose) or http://localhost:8000 (local)
#
# PRODUCTION (Lambda mode — direct invoke):
#   ENGINE_INVOCATION_MODE=lambda
#   ENGINE_LAMBDA_FUNCTION_NAME=program-builder
#   ENGINE_LAMBDA_REGION=us-east-1
ENGINE_INVOCATION_MODE=http
ENGINE_URL=http://program-builder:8000
ENGINE_LAMBDA_FUNCTION_NAME=program-builder
ENGINE_LAMBDA_REGION=us-east-1
