{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/program_definition.schema.json",
  "title": "ProgramDefinition",
  "type": "object",
  "required": [
    "program_id",
    "version",
    "parameter_spec",
    "template",
    "prescriptions",
    "rules",
    "validation"
  ],
  "properties": {
    "program_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "parameter_spec": {
      "type": "object",
      "required": [
        "fields"
      ],
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "key",
              "type"
            ],
            "properties": {
              "key": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": [
                  "number",
                  "string",
                  "enum",
                  "boolean",
                  "string_array",
                  "number_array",
                  "object"
                ]
              },
              "required": {
                "type": "boolean"
              },
              "required_if": {
                "type": "string"
              },
              "visible_if": {
                "type": "string"
              },
              "default_expr": {
                "type": "string"
              },
              "min": {
                "type": "number"
              },
              "max": {
                "type": "number"
              },
              "enum": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "exercise_library_ref": {
      "type": "object",
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "file",
            "url",
            "embedded"
          ]
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "template": {
      "type": "object",
      "required": [
        "weeks",
        "days_per_week",
        "sessions"
      ],
      "properties": {
        "weeks": {
          "type": "object",
          "required": [
            "min",
            "max"
          ],
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 1
            },
            "max": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        },
        "days_per_week": {
          "type": "object",
          "required": [
            "min",
            "max"
          ],
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 1,
              "maximum": 7
            },
            "max": {
              "type": "integer",
              "minimum": 1,
              "maximum": 7
            }
          },
          "additionalProperties": false
        },
        "sessions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "day_index",
              "tags",
              "blocks"
            ],
            "properties": {
              "day_index": {
                "type": "integer",
                "minimum": 1,
                "maximum": 7
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "optional": {
                "type": "boolean"
              },
              "blocks": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "type",
                    "exercise_selector",
                    "prescription_ref"
                  ],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": [
                        "main_lift",
                        "secondary_lift",
                        "accessory",
                        "conditioning_steady",
                        "conditioning_intervals",
                        "circuit",
                        "mobility",
                        "warmup",
                        "cooldown"
                      ]
                    },
                    "tags": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "optional": {
                      "type": "boolean"
                    },
                    "exercise_selector": {
                      "type": "object",
                      "required": [
                        "count",
                        "include_tags"
                      ],
                      "properties": {
                        "count": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 10
                        },
                        "include_tags": {
                          "type": "array",
                          "minItems": 1,
                          "items": {
                            "type": "string"
                          }
                        },
                        "exclude_tags": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "prefer_tags": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "allow_repeats": {
                          "type": "boolean"
                        }
                      },
                      "additionalProperties": true
                    },
                    "prescription_ref": {
                      "type": "string"
                    },
                    "constraints": {
                      "type": "object",
                      "properties": {
                        "block_fatigue_cap_expr": {
                          "type": "string"
                        }
                      },
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "prescriptions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "mode"
        ],
        "properties": {
          "mode": {
            "type": "string"
          },
          "variables": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "output_mapping": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}