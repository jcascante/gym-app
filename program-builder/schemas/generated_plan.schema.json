{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/generated_plan.schema.json",
  "title": "GeneratedPlan",
  "type": "object",
  "required": [
    "program_id",
    "program_version",
    "generated_at",
    "inputs_echo",
    "weeks",
    "warnings",
    "repairs"
  ],
  "properties": {
    "program_id": {
      "type": "string"
    },
    "program_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "inputs_echo": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "repairs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "weeks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "week",
          "sessions"
        ],
        "properties": {
          "week": {
            "type": "integer",
            "minimum": 1
          },
          "sessions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "day",
                "blocks",
                "metrics"
              ],
              "properties": {
                "day": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 7
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "blocks": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object"
                  }
                },
                "metrics": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "plan_summary": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}