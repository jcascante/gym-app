{
  "program_id": "push_legs_pull_hams_fb_4w_v1",
  "version": "1.0.0",
  "name": "Push+Legs / Pull+Hams / Full Body Fuerza — 4 semanas (3 días pesas + Conditioning)",
  "description": "Variante 5: 3 días de pesas de alta intensidad por sesión + 1 conditioning opcional. D1 (Push+Legs A): pecho×2 + cuádriceps×2 + tríceps. D2 (Pull+Hams): espalda×2 + femorales×2 + bíceps. D4 (Full Body Fuerza): pecho + espalda + cuádriceps + deltoides×2. Mayor volumen por grupo con menor frecuencia semanal.",
  "parameter_spec": {
    "fields": [
      {
        "key": "athlete.level",
        "type": "enum",
        "enum": ["novice", "intermediate", "advanced"],
        "required": true
      },
      {
        "key": "athlete.equipment",
        "type": "string_array",
        "required": true
      },
      {
        "key": "athlete.restrictions",
        "type": "string_array",
        "required": false,
        "default_expr": "[]"
      },
      {
        "key": "rules.accessory_rir_target",
        "type": "number",
        "required": true,
        "min": 0,
        "max": 5,
        "default_expr": "2"
      },
      {
        "key": "rules.rounding_profile",
        "type": "enum",
        "enum": ["none", "plate_2p5kg", "db_2kg"],
        "required": true,
        "default_expr": "'plate_2p5kg'"
      }
    ]
  },
  "exercise_library_ref": {
    "type": "file",
    "path": "data/exercise_library_v1.json"
  },
  "template": {
    "weeks": { "min": 4, "max": 4 },
    "days_per_week": { "min": 3, "max": 4 },
    "sessions": [
      {
        "day_index": 1,
        "tags": ["push", "legs", "push_legs_a", "chest_focus", "quad_focus"],
        "optional": false,
        "blocks": [
          {
            "id": "d1_chest1",
            "type": "main_lift",
            "tags": ["chest", "horizontal_push"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["chest", "horizontal_push", "bench_main", "bench_secondary"],
              "prefer_tags": ["compound", "barbell"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d1_chest2",
            "type": "secondary_lift",
            "tags": ["chest", "upper_chest"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["chest", "chest_accessory", "upper_chest", "press_secondary"],
              "prefer_tags": ["dumbbell", "cable"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d1_quad1",
            "type": "main_lift",
            "tags": ["quads", "squat"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["squat_main", "squat_secondary"],
              "prefer_tags": ["barbell", "compound"]
            },
            "prescription_ref": "rx_strength_lower"
          },
          {
            "id": "d1_quad2",
            "type": "secondary_lift",
            "tags": ["quads"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["quads", "quads_accessory", "quads_isolation"]
            },
            "prescription_ref": "rx_strength_lower"
          },
          {
            "id": "d1_tri",
            "type": "accessory",
            "tags": ["triceps"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["triceps", "triceps_accessory"]
            },
            "prescription_ref": "rx_hyp_tri"
          },
          {
            "id": "d1_abs",
            "type": "accessory",
            "tags": ["core", "abs"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["abs", "core", "core_anti_extension", "core_flexion"]
            },
            "prescription_ref": "rx_timed_abs"
          }
        ]
      },
      {
        "day_index": 2,
        "tags": ["pull", "legs", "pull_hams", "back_focus", "ham_focus"],
        "optional": false,
        "blocks": [
          {
            "id": "d2_back1",
            "type": "main_lift",
            "tags": ["back", "vertical_pull"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["vertical_pull_main", "vertical_pull_secondary", "back"],
              "prefer_tags": ["compound", "barbell"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d2_back2",
            "type": "secondary_lift",
            "tags": ["back", "horizontal_pull"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["horizontal_pull_secondary", "horizontal_pull_accessory", "back"],
              "prefer_tags": ["horizontal_pull", "barbell"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d2_ham1",
            "type": "main_lift",
            "tags": ["hamstrings", "hinge"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["hinge_main", "hinge_secondary", "hamstrings"],
              "prefer_tags": ["barbell", "compound"]
            },
            "prescription_ref": "rx_strength_lower"
          },
          {
            "id": "d2_ham2",
            "type": "secondary_lift",
            "tags": ["hamstrings"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["hamstrings_isolation", "hamstrings_accessory"]
            },
            "prescription_ref": "rx_strength_lower"
          },
          {
            "id": "d2_bi",
            "type": "accessory",
            "tags": ["biceps"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["biceps", "biceps_accessory"]
            },
            "prescription_ref": "rx_hyp_bi"
          },
          {
            "id": "d2_abs",
            "type": "accessory",
            "tags": ["core", "abs"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["abs", "core", "core_anti_extension", "core_flexion"]
            },
            "prescription_ref": "rx_timed_abs"
          }
        ]
      },
      {
        "day_index": 3,
        "tags": ["conditioning"],
        "optional": true,
        "blocks": [
          {
            "id": "d3_conditioning",
            "type": "conditioning_steady",
            "tags": ["conditioning", "cardio"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["carry", "core", "core_anti_rotation"]
            },
            "prescription_ref": "rx_conditioning_steady"
          }
        ]
      },
      {
        "day_index": 4,
        "tags": ["full_body", "strength_focus", "delts_focus"],
        "optional": false,
        "blocks": [
          {
            "id": "d4_chest",
            "type": "main_lift",
            "tags": ["chest", "horizontal_push"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["chest", "horizontal_push", "bench_secondary", "press_secondary"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d4_back",
            "type": "secondary_lift",
            "tags": ["back"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["horizontal_pull_secondary", "vertical_pull_secondary", "back"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d4_quad",
            "type": "main_lift",
            "tags": ["quads", "squat"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["squat_main", "squat_secondary"],
              "prefer_tags": ["barbell", "compound"]
            },
            "prescription_ref": "rx_strength_lower"
          },
          {
            "id": "d4_delts_lat",
            "type": "accessory",
            "tags": ["delts", "shoulders"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["delts_lateral", "delts_front", "delts_side", "ohp_secondary", "vertical_push"],
              "prefer_tags": ["delts_lateral", "delts_side"]
            },
            "prescription_ref": "rx_hyp_delts"
          },
          {
            "id": "d4_delts_rear",
            "type": "accessory",
            "tags": ["delts_rear", "rear_delt"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["delts_rear", "delts_posterior", "rear_delt", "delts_front"]
            },
            "prescription_ref": "rx_hyp_delts"
          },
          {
            "id": "d4_abs",
            "type": "accessory",
            "tags": ["core", "abs"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["abs", "core", "core_anti_extension", "core_flexion"]
            },
            "prescription_ref": "rx_timed_abs"
          }
        ]
      }
    ]
  },
  "prescriptions": {
    "rx_hyp_upper": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,2,3])",
        "reps_min_expr": "choose(ctx.week,[10,14,15,15])",
        "reps_max_expr": "choose(ctx.week,[10,14,15,15])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_strength_lower": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,4])",
        "reps_min_expr": "choose(ctx.week,[6,6,6,8])",
        "reps_max_expr": "choose(ctx.week,[6,6,6,8])",
        "target_rir_expr": "2"
      }
    },
    "rx_hyp_tri": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,2])",
        "reps_min_expr": "20",
        "reps_max_expr": "20",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_hyp_bi": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,3])",
        "reps_min_expr": "choose(ctx.week,[15,15,15,20])",
        "reps_max_expr": "choose(ctx.week,[15,15,15,20])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_hyp_delts": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,3])",
        "reps_min_expr": "choose(ctx.week,[15,15,15,20])",
        "reps_max_expr": "choose(ctx.week,[15,15,15,20])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_timed_abs": {
      "mode": "steady_state",
      "output_mapping": {
        "duration_minutes_expr": "1",
        "intensity_target_expr": "choose(ctx.week,['30s','40s','50s','60s'])",
        "notes_expr": "'Timed hold — target: ' + choose(ctx.week,['30s','40s','50s','60s'])"
      }
    },
    "rx_conditioning_steady": {
      "mode": "steady_state",
      "output_mapping": {
        "duration_minutes_expr": "choose(ctx.week,[20,25,25,20])",
        "intensity_target_expr": "'zone2'",
        "notes_expr": "'Low-intensity steady-state cardio (zone 2)'"
      }
    }
  },
  "rules": {
    "expression_language": "v1",
    "rounding_profiles": {
      "none": { "type": "none" },
      "plate_2p5kg": { "type": "plate", "increment_kg": 2.5 },
      "db_2kg": { "type": "dumbbell", "increment_kg": 2.0 }
    },
    "defaults": {
      "rounding_profile_key_expr": "ctx.rules.rounding_profile"
    },
    "selection": {
      "respect_equipment": true,
      "respect_contraindications": true,
      "avoid_same_exercise_within_days": 2,
      "avoid_same_swap_group_within_days": 2
    },
    "fatigue_model": {
      "per_set_expr": "exercise.fatigue_cost * intensity_factor"
    }
  },
  "validation": {
    "hard": {
      "max_weekly_volume_by_key": {
        "key_expr": "muscle",
        "limit_expr": "choose(ctx.athlete.level, {'novice':20,'intermediate':24,'advanced':30})"
      },
      "max_fatigue_per_session_expr": "12",
      "max_fatigue_per_week_expr": "50"
    },
    "soft": {
      "warnings": [
        {
          "if_expr": "ctx.plan.weekly_volume.muscle.chest < 4",
          "message": "Chest volume is below recommended minimum (3-day program, 2 sessions/week)."
        },
        {
          "if_expr": "ctx.plan.weekly_volume.muscle.back < 4",
          "message": "Back volume is below recommended minimum (3-day program, 2 sessions/week)."
        },
        {
          "if_expr": "ctx.plan.weekly_volume.muscle.hamstrings < 3",
          "message": "Hamstring volume is below recommended minimum for posterior chain development."
        }
      ]
    },
    "repair": {
      "strategy_order": [
        "reduce_accessory_sets",
        "swap_to_lower_fatigue_variant",
        "drop_optional_blocks"
      ],
      "limits": {
        "max_repairs_per_session": 8,
        "max_repairs_per_plan": 40
      }
    }
  }
}
