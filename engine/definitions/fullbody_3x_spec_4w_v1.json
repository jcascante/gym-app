{
  "program_id": "fullbody_3x_spec_4w_v1",
  "version": "1.0.0",
  "name": "Full Body x3 + Especialización — 4 semanas (FB-A · FB-B · FB-C · Espec.)",
  "description": "Variante 3: 3 días full body con diferentes énfasis + 1 día de especialización en grupos rezagados. Máxima frecuencia (3×/semana por músculo principal). FB-A énfasis empuje/quads. FB-B énfasis tracción/isquiotibiales. FB-C énfasis piernas al inicio. Día 5: alto volumen en deltoides, brazos y pantorrillas.",
  "parameter_spec": {
    "fields": [
      {
        "key": "athlete.level",
        "type": "enum",
        "enum": ["novice", "intermediate", "advanced"],
        "required": true
      },
      {
        "key": "athlete.equipment",
        "type": "string_array",
        "required": true
      },
      {
        "key": "athlete.restrictions",
        "type": "string_array",
        "required": false,
        "default_expr": "[]"
      },
      {
        "key": "rules.accessory_rir_target",
        "type": "number",
        "required": true,
        "min": 0,
        "max": 5,
        "default_expr": "2"
      },
      {
        "key": "rules.rounding_profile",
        "type": "enum",
        "enum": ["none", "plate_2p5kg", "db_2kg"],
        "required": true,
        "default_expr": "'plate_2p5kg'"
      }
    ]
  },
  "exercise_library_ref": {
    "type": "file",
    "path": "data/exercise_library_v1.json"
  },
  "template": {
    "weeks": { "min": 4, "max": 4 },
    "days_per_week": { "min": 4, "max": 5 },
    "sessions": [
      {
        "day_index": 1,
        "tags": ["full_body", "full_body_a", "push_focus", "quad_focus"],
        "optional": false,
        "blocks": [
          {
            "id": "d1_chest",
            "type": "main_lift",
            "tags": ["chest", "horizontal_push"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["chest", "horizontal_push", "bench_main", "bench_secondary"],
              "prefer_tags": ["compound", "barbell"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d1_back",
            "type": "secondary_lift",
            "tags": ["back"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["horizontal_pull_secondary", "vertical_pull_secondary", "back"],
              "prefer_tags": ["compound"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d1_quads",
            "type": "main_lift",
            "tags": ["quads", "squat"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["squat_main", "squat_secondary"],
              "prefer_tags": ["barbell", "compound"]
            },
            "prescription_ref": "rx_strength_lower"
          },
          {
            "id": "d1_delts",
            "type": "accessory",
            "tags": ["delts", "shoulders"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["delts_lateral", "delts_front", "delts_side", "ohp_secondary", "vertical_push"]
            },
            "prescription_ref": "rx_hyp_delts"
          },
          {
            "id": "d1_tri",
            "type": "accessory",
            "tags": ["triceps"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["triceps", "triceps_accessory"]
            },
            "prescription_ref": "rx_hyp_tri"
          },
          {
            "id": "d1_abs",
            "type": "accessory",
            "tags": ["core", "abs"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["abs", "core", "core_anti_extension", "core_flexion"]
            },
            "prescription_ref": "rx_timed_abs"
          }
        ]
      },
      {
        "day_index": 2,
        "tags": ["full_body", "full_body_b", "pull_focus", "ham_focus"],
        "optional": false,
        "blocks": [
          {
            "id": "d2_back",
            "type": "main_lift",
            "tags": ["back", "vertical_pull"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["vertical_pull_main", "vertical_pull_secondary", "back"],
              "prefer_tags": ["compound", "barbell"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d2_chest",
            "type": "secondary_lift",
            "tags": ["chest"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["chest", "chest_accessory", "press_secondary", "horizontal_push"],
              "prefer_tags": ["dumbbell", "cable"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d2_hams",
            "type": "main_lift",
            "tags": ["hamstrings", "hinge"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["hinge_main", "hinge_secondary", "hamstrings"],
              "prefer_tags": ["barbell", "compound"]
            },
            "prescription_ref": "rx_strength_lower"
          },
          {
            "id": "d2_bi",
            "type": "accessory",
            "tags": ["biceps"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["biceps", "biceps_accessory"]
            },
            "prescription_ref": "rx_hyp_bi"
          },
          {
            "id": "d2_delts",
            "type": "accessory",
            "tags": ["delts", "shoulders"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["delts_lateral", "delts_front", "delts_side", "ohp_secondary"]
            },
            "prescription_ref": "rx_hyp_delts"
          },
          {
            "id": "d2_abs",
            "type": "accessory",
            "tags": ["core", "abs"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["abs", "core", "core_anti_extension", "core_flexion"]
            },
            "prescription_ref": "rx_timed_abs"
          }
        ]
      },
      {
        "day_index": 3,
        "tags": ["conditioning"],
        "optional": true,
        "blocks": [
          {
            "id": "d3_conditioning",
            "type": "conditioning_steady",
            "tags": ["conditioning", "cardio"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["carry", "core", "core_anti_rotation"]
            },
            "prescription_ref": "rx_conditioning_steady"
          }
        ]
      },
      {
        "day_index": 4,
        "tags": ["full_body", "full_body_c", "leg_focus"],
        "optional": false,
        "blocks": [
          {
            "id": "d4_quads",
            "type": "main_lift",
            "tags": ["quads", "squat"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["squat_main", "squat_secondary"],
              "prefer_tags": ["barbell", "compound"]
            },
            "prescription_ref": "rx_strength_lower"
          },
          {
            "id": "d4_hams",
            "type": "secondary_lift",
            "tags": ["hamstrings", "hinge"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["hinge_secondary", "hamstrings", "hamstrings_accessory"],
              "prefer_tags": ["compound", "barbell"]
            },
            "prescription_ref": "rx_strength_lower"
          },
          {
            "id": "d4_chest",
            "type": "secondary_lift",
            "tags": ["chest"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["chest", "horizontal_push", "bench_secondary", "press_secondary"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d4_back",
            "type": "secondary_lift",
            "tags": ["back"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["horizontal_pull_secondary", "horizontal_pull_accessory", "back"]
            },
            "prescription_ref": "rx_hyp_upper"
          },
          {
            "id": "d4_delts",
            "type": "accessory",
            "tags": ["delts", "shoulders"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["delts_lateral", "delts_front", "delts_side", "ohp_secondary"]
            },
            "prescription_ref": "rx_hyp_delts"
          },
          {
            "id": "d4_abs",
            "type": "accessory",
            "tags": ["core", "abs"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["abs", "core", "core_anti_extension", "core_flexion"]
            },
            "prescription_ref": "rx_timed_abs"
          }
        ]
      },
      {
        "day_index": 5,
        "tags": ["specialization", "arms", "delts_focus"],
        "optional": false,
        "blocks": [
          {
            "id": "d5_delts_lat",
            "type": "accessory",
            "tags": ["delts_lateral", "shoulders"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["delts_lateral", "delts_side", "delts_front", "ohp_secondary", "vertical_push"],
              "prefer_tags": ["delts_lateral", "delts_side"]
            },
            "prescription_ref": "rx_hyp_delts"
          },
          {
            "id": "d5_delts_rear",
            "type": "accessory",
            "tags": ["delts_rear", "rear_delt"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["delts_rear", "delts_posterior", "rear_delt", "delts_front"]
            },
            "prescription_ref": "rx_hyp_delts"
          },
          {
            "id": "d5_tri",
            "type": "accessory",
            "tags": ["triceps"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["triceps", "triceps_accessory"]
            },
            "prescription_ref": "rx_hyp_tri"
          },
          {
            "id": "d5_bi",
            "type": "accessory",
            "tags": ["biceps"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["biceps", "biceps_accessory"]
            },
            "prescription_ref": "rx_hyp_bi"
          },
          {
            "id": "d5_calves",
            "type": "accessory",
            "tags": ["calves"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["calves_focus", "calves_isolation"]
            },
            "prescription_ref": "rx_hyp_calves"
          },
          {
            "id": "d5_abs",
            "type": "accessory",
            "tags": ["core", "abs"],
            "exercise_selector": {
              "count": 1,
              "include_tags": ["abs", "core", "core_anti_extension", "core_flexion"]
            },
            "prescription_ref": "rx_timed_abs"
          }
        ]
      }
    ]
  },
  "prescriptions": {
    "rx_hyp_upper": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,2,3])",
        "reps_min_expr": "choose(ctx.week,[10,14,15,15])",
        "reps_max_expr": "choose(ctx.week,[10,14,15,15])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_strength_lower": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,4])",
        "reps_min_expr": "choose(ctx.week,[6,6,6,8])",
        "reps_max_expr": "choose(ctx.week,[6,6,6,8])",
        "target_rir_expr": "2"
      }
    },
    "rx_hyp_delts": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,3])",
        "reps_min_expr": "choose(ctx.week,[15,15,15,20])",
        "reps_max_expr": "choose(ctx.week,[15,15,15,20])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_hyp_tri": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,2])",
        "reps_min_expr": "20",
        "reps_max_expr": "20",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_hyp_bi": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,3])",
        "reps_min_expr": "choose(ctx.week,[15,15,15,20])",
        "reps_max_expr": "choose(ctx.week,[15,15,15,20])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_hyp_calves": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[3,4,4,3])",
        "reps_min_expr": "choose(ctx.week,[15,15,20,20])",
        "reps_max_expr": "choose(ctx.week,[15,15,20,20])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_timed_abs": {
      "mode": "steady_state",
      "output_mapping": {
        "duration_minutes_expr": "1",
        "intensity_target_expr": "choose(ctx.week,['30s','40s','50s','60s'])",
        "notes_expr": "'Timed hold — target: ' + choose(ctx.week,['30s','40s','50s','60s'])"
      }
    },
    "rx_conditioning_steady": {
      "mode": "steady_state",
      "output_mapping": {
        "duration_minutes_expr": "choose(ctx.week,[20,25,25,20])",
        "intensity_target_expr": "'zone2'",
        "notes_expr": "'Low-intensity steady-state cardio (zone 2)'"
      }
    }
  },
  "rules": {
    "expression_language": "v1",
    "rounding_profiles": {
      "none": { "type": "none" },
      "plate_2p5kg": { "type": "plate", "increment_kg": 2.5 },
      "db_2kg": { "type": "dumbbell", "increment_kg": 2.0 }
    },
    "defaults": {
      "rounding_profile_key_expr": "ctx.rules.rounding_profile"
    },
    "selection": {
      "respect_equipment": true,
      "respect_contraindications": true,
      "avoid_same_exercise_within_days": 2,
      "avoid_same_swap_group_within_days": 2
    },
    "fatigue_model": {
      "per_set_expr": "exercise.fatigue_cost * intensity_factor"
    }
  },
  "validation": {
    "hard": {
      "max_weekly_volume_by_key": {
        "key_expr": "muscle",
        "limit_expr": "choose(ctx.athlete.level, {'novice':24,'intermediate':30,'advanced':36})"
      },
      "max_fatigue_per_session_expr": "12",
      "max_fatigue_per_week_expr": "55"
    },
    "soft": {
      "warnings": [
        {
          "if_expr": "ctx.plan.weekly_volume.muscle.chest < 6",
          "message": "Chest volume is below recommended minimum for hypertrophy (3x/week program)."
        },
        {
          "if_expr": "ctx.plan.weekly_volume.muscle.back < 6",
          "message": "Back volume is below recommended minimum for hypertrophy (3x/week program)."
        },
        {
          "if_expr": "ctx.plan.weekly_volume.muscle.hamstrings < 4",
          "message": "Hamstring volume is below recommended minimum for posterior chain development."
        }
      ]
    },
    "repair": {
      "strategy_order": [
        "reduce_accessory_sets",
        "swap_to_lower_fatigue_variant",
        "drop_optional_blocks"
      ],
      "limits": {
        "max_repairs_per_session": 8,
        "max_repairs_per_plan": 40
      }
    }
  }
}
