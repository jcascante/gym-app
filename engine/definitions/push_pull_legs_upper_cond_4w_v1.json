  "prescriptions": {
    "rx_hyp_upper": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,2,3])",
        "reps_min_expr": "choose(ctx.week,[10,14,15,15])",
        "reps_max_expr": "choose(ctx.week,[10,14,15,15])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_hyp_delts": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,3])",
        "reps_min_expr": "choose(ctx.week,[15,15,15,20])",
        "reps_max_expr": "choose(ctx.week,[15,15,15,20])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_hyp_tri": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,2])",
        "reps_min_expr": "20",
        "reps_max_expr": "20",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_hyp_bi": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,3])",
        "reps_min_expr": "choose(ctx.week,[15,15,15,20])",
        "reps_max_expr": "choose(ctx.week,[15,15,15,20])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_strength_lower": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,4])",
        "reps_min_expr": "choose(ctx.week,[6,6,6,8])",
        "reps_max_expr": "choose(ctx.week,[6,6,6,8])",
        "target_rir_expr": "2"
      }
    },
    "rx_hyp_glutes": {
      "mode": "reps_range_rir",
      "output_mapping": {
        "sets_expr": "choose(ctx.week,[2,3,4,3])",
        "reps_min_expr": "choose(ctx.week,[10,10,10,12])",
        "reps_max_expr": "choose(ctx.week,[10,10,10,12])",
        "target_rir_expr": "ctx.rules.accessory_rir_target"
      }
    },
    "rx_timed_abs": {
      "mode": "steady_state",
      "output_mapping": {
        "duration_minutes_expr": "1",
        "intensity_target_expr": "choose(ctx.week,['30s','40s','50s','60s'])",
        "notes_expr": "'Timed hold — target: ' + choose(ctx.week,['30s','40s','50s','60s'])"
      }
    },
    "rx_conditioning_short": {
      "mode": "steady_state",
      "output_mapping": {
        "duration_minutes_expr": "choose(ctx.week,[10,12,15,10])",
        "intensity_target_expr": "'zone2'",
        "notes_expr": "'Low-intensity steady-state cardio (zone 2)'"
      }
    }
  },
  "rules": {
    "expression_language": "v1",
    "rounding_profiles": {
      "none": {
        "type": "none"
      },
      "plate_2p5kg": {
        "type": "plate",
        "increment_kg": 2.5
      },
      "db_2kg": {
        "type": "dumbbell",
        "increment_kg": 2.0
      }
    },
    "defaults": {
      "rounding_profile_key_expr": "ctx.rules.rounding_profile"
    },
    "selection": {
      "respect_equipment": true,
      "respect_contraindications": true,
      "avoid_same_exercise_within_days": 2,
      "avoid_same_swap_group_within_days": 2
    },
    "fatigue_model": {
      "per_set_expr": "exercise.fatigue_cost * intensity_factor"
    }
  },
  "validation": {
    "hard": {
      "max_weekly_volume_by_key": {
        "key_expr": "muscle",
        "limit_expr": "choose(ctx.athlete.level, {'novice':24,'intermediate':30,'advanced':36})"
      },
      "max_fatigue_per_session_expr": "12",
      "max_fatigue_per_week_expr": "60"
    },
    "soft": {
      "warnings": [
        {
          "if_expr": "ctx.plan.weekly_volume.muscle.chest < 6",
          "message": "Chest volume is below recommended minimum for hypertrophy (high-frequency program)."
        },
        {
          "if_expr": "ctx.plan.weekly_volume.muscle.back < 6",
          "message": "Back volume is below recommended minimum for hypertrophy (high-frequency program)."
        },
        {
          "if_expr": "ctx.plan.weekly_volume.muscle.hamstrings < 4",
          "message": "Hamstring volume is below recommended minimum for posterior chain development."
        }
      ]
    },
    "repair": {
      "strategy_order": [
        "reduce_accessory_sets",
        "swap_to_lower_fatigue_variant",
        "drop_optional_blocks"
      ],
      "limits": {
        "max_repairs_per_session": 8,
        "max_repairs_per_plan": 40
      }
    }
  }
}