{
  "program_id": "push_pull_legs_upper_cond_4w_v1",
  "version": "1.0.0",
  "name": "Push · Pull · Legs · Upper · Conditioning — 4 semanas (5 días / Alta Frecuencia)",
  "description": "Variante 4: 5 días alta frecuencia. D1 Push A (pecho×2 + tríceps×2 + hombros). D2 Pull A (espalda×2 + bíceps×2 + deltoides posterior). D3 Legs (cuádriceps×2 + femorales×2 + glúteos). D4 Upper Full sin abs (pecho+espalda+deltoides×2+tríceps+bíceps). D5 Conditioning+Fuerza: segunda frecuencia piernas + pecho + espalda + bloque metabólico zone2 corto. Cada grupo muscular 2–3×/semana.",
  "category": "High Frequency",
  "tags": [
    "hypertrophy",
    "conditioning"
  ],
  "parameter_spec": {
    "fields": [
      {
        "key": "athlete.level",
        "type": "enum",
        "enum": [
          "novice",
          "intermediate",
          "advanced"
        ],
        "required": true
      },
      {
        "key": "athlete.equipment",
        "type": "string_array",
