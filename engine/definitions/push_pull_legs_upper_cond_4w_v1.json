      },
      {
        "key": "athlete.restrictions",
        "type": "string_array",
        "required": false,
        "default_expr": "[]"
      },
      {
        "key": "rules.accessory_rir_target",
        "type": "number",
        "required": true,
        "min": 0,
        "max": 5,
        "default_expr": "2"
      },
      {
        "key": "rules.rounding_profile",
